{
  "functions": {
    "api/transcribe.js": { "maxDuration": 60, "memory": 1024 },
    "api/ingest.js":     { "maxDuration": 30, "memory": 512  }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1.js" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/((?!api|dashboard).*)", "destination": "/index.html" }
  ]
}
